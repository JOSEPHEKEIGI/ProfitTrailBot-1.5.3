; ===== Session & Activity Monitoring =====
Use_Session_Filter=false
London_Session_Start=8.0
London_Session_End=11.5
NewYork_Session_Start=13.0
NewYork_Session_End=16.5

; ===== AI Trend Prediction Module - OPTIMIZED =====
Enable_AI_Trend_Predictor=true
AI_Signal_Generation_Mode=1                   ; PRIMARY mode (AI generates signals)
AI_Trend_Confidence=2

; ===== AI Confidence Thresholds - OPTIMIZED =====
AI_Buy_Confidence_Threshold=0.50              ; Throughput: minimum runtime buy threshold
AI_Sell_Confidence_Threshold=0.40             ; Throughput: minimum runtime sell threshold
AI_Neutral_Band=0.02                          ; Default neutral zone width
AI_Low_Confidence_Threshold=0.55              ; FIX I9: below buy threshold (0.55 < 0.60) for proper low-conf zone
AI_Low_Confidence_Extra_RR=0.0

; ===== AI Multi-Structure Validation - OPTIMIZED =====
Enable_AI_MTF_Regime_Filter=false
AI_Min_Aligned_Structures=1                   ; Throughput: minimum alignment
AI_Max_Opposing_Structures=2                  ; Throughput: allow opposing structures
AI_Min_Directional_Edge=0.0                   ; Throughput: no edge gate

; ===== AI Expected Value & Risk Filters - OPTIMIZED =====
AI_Enable_EV_Filter=false
AI_Min_Expected_Value_R=0.0                   ; Throughput: no EV gate
AI_Max_Spread_to_ATR=1.00                     ; Throughput: broad spread validation

; ===== AI Candle Quality Filter - OPTIMIZED =====
Enable_AI_Candle_Quality_Filter=false
AI_Candle_Quality_Lookback_Bars=3
AI_Candle_Min_Quality_Score=0.0               ; Throughput: no candle quality floor
AI_Candle_Min_Body_Ratio=0.35                 ; better candle structure
AI_Candle_Max_Opposite_Wick_Ratio=0.50        ; reduced wick tolerance
AI_Candle_ATR_Min_Range_Factor=0.25           ; minimum movement required
AI_Candle_ATR_Max_Range_Factor=2.00           ; maximum movement limit

; ===== AI Training & Hot Reload =====
Enable_AI_Training_Export=false
Enable_AI_Continuous_Training_Export=false
Enable_AI_Model_HotReload=true
AI_Model_HotReload_Check_Seconds=30
Enable_AI_Scaler=true

; ===== AI Signal Requirements =====
AI_Require_Agreement=false                    ; Throughput: do not require AI directional agreement
AI_Use_Enhanced_Targets=true
AI_Use_Risk_Adjustment=true

; ===== AI DLL Integration (Optional) =====
Enable_External_AI=true
External_AI_Mode=0

; ===== Institutional Feature Toggles =====
