Max_Tick_Age_Seconds=30
Max_Margin_Usage_Pct=0.0
Min_Margin_Level_Pct=0.0
Skip_MinLot_Overrisk=true
Allow_Neutral_Trend_Trading=true
AI_Allow_Relaxed_TieBreak=true

; ===== Strategy Timeframes & Filters =====
Allow_Range_Trading=true
Require_All_TF_Agreement=false
Enable_Confluence_Check=false
Enable_HTF_Bias_Check=false
